# Copy to .env.local and fill in (or set as Workers env vars for the prod deploy).
# .env.local is gitignored; never commit real values.

# --- Web Push (VAPID) ---
# Generate with:  node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@your-domain.example
# "minimal" | "named" — privacy mode for push notification payload
PUSH_PRIVACY=named

# --- Audit + verification hashing secrets ---
# Any sufficiently random string; rotate before production.
FOH_HASH_SECRET=
FOH_AUDIT_SECRET=
FOH_VERIFY_SECRET=

# --- Real Airship API (optional) ---
# When both PAT and ACCOUNT_ID are set, contact lookups that don't match a seeded
# demo persona fall through to the real Airship public API.
# Public docs: https://developers.airship.co.uk
AIRSHIP_API_BASE_URL=https://api.airship.co.uk/v1
AIRSHIP_PAT=
AIRSHIP_ACCOUNT_ID=
